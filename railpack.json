{
    "$schema": "https://schema.railpack.com",
    "steps": {
        "install": {
            "commands": [
                "pip install -r requirements.txt"
            ]
        },
        "build": {
            "inputs": [
                {
                    "step": "install"
                }
            ]
        }
    },
    "deploy": {
        "startCommand": "python -m src.app"
    }
}